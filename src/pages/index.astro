---
import "../styles/global.css";

const pageTitle = "Eclipse 30618";
const pageDescription =
  "Eclipse 30618 is preparing a new public website for team updates, season information, and community outreach.";

const teammates = [
  { name: "Ali", role: "Captain" },
  { name: "Adam", role: "Vice Captain" },
  { name: "Zakariya", role: "Programming / CAD" },
  { name: "Muhammad", role: "CAD" },
  { name: "Nizar", role: "Programming" },
  { name: "Hadi", role: "Programming" },
  { name: "Yahia", role: "Programming" },
  { name: "Rwyd", role: "Business" },
];

const contactMethods = [
  {
    label: "Email",
    value: "team@eclipse30618.com",
    link: "mailto:team@eclipse30618.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: "Instagram",
    value: "@eclipse30618",
    link: "https://instagram.com/eclipse.30618",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: "YouTube",
    value: "YouTube Channel",
    link: "https://www.youtube.com/channel/UCyq_GnzewMy3H9HJDqq6XLw",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.56 49.56 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>`,
  },
];

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://eclipse30618.com/" />
    <meta property="og:image" content="https://eclipse30618.com/eclipse-hero.png" />
    <meta name="theme-color" content="#050609" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="scroll-eclipse-scene scroll-eclipse-scene--drift" aria-hidden="true">
      <img src="/scroll-eclipse.webp" alt="" decoding="async" />
    </div>
    <div class="spinning-gear-scene" aria-hidden="true">
      <div class="spinning-gear"></div>
    </div>


    <div class="top-bar-container">
      <p class="page-title-tab" data-active-page-title aria-live="polite">Eclipse 30618</p>
    </div>

    <nav class="page-tabs" aria-label="Primary">
      <a class="top-bar__link" href="#home">HOME</a>
      <a class="top-bar__link" href="#team">TEAM</a>
      <a class="top-bar__link" href="#contact">CONTACT</a>
      <a class="top-bar__link" href="#resources">LEARN</a>
    </nav>

    <main class="site-shell">
      <section id="home" class="hero" aria-labelledby="site-title">
        <img
          class="hero__image"
          src="/eclipse-hero.png"
          alt=""
          loading="eager"
          decoding="async"
        />
        <div class="hero__shade" aria-hidden="true"></div>

        <div class="hero__content">
          <p class="kicker">FTC Team 30618</p>
          <h1 id="site-title" class="hero-title" aria-label="Eclipse 30618">
            <span class="hero-title__word" aria-hidden="true">
              E<img class="hero-title__crescent" src="/crescent-c.svg" alt="c" decoding="async" />lipse
            </span>
            <span class="hero-title__number" aria-hidden="true">30618</span>
          </h1>
          <p class="lede">
            Our public website is coming soon with team updates, season notes,
            outreach work, and sponsor information.
          </p>
          <div class="status-row" aria-label="Website status">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Website in progress</span>
          </div>
        </div>
      </section>

      <section id="team" class="team-page">
        <img class="team-page__image" src="/eclipse-hero.png" alt="" />
        <div class="team-page__shade" aria-hidden="true"></div>

        <div class="team-panel">
          <h1 id="team-title" class="page-heading">Team Roster</h1>

          <ul class="team-grid" aria-label="Team members">
            {
              teammates.map((member) => (
                <li class="team-card">
                  <span class="team-card__name">{member.name}</span>
                  <span class="team-card__role">{member.role}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section id="contact" class="team-page">
        <img class="team-page__image" src="/eclipse-hero.png" alt="" />
        <div class="team-page__shade" aria-hidden="true"></div>

        <div class="team-panel">
          <h1 id="contact-title" class="page-heading">Contact Us</h1>

          <ul class="team-grid contact-grid" aria-label="Contact methods">
            {
              contactMethods.map((method) => (
                <li class="team-card">
                  <a
                    href={method.link}
                    style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;"
                  >
                    <div
                      style="margin-bottom: auto; color: var(--teal); opacity: 0.8;"
                      set:html={method.icon}
                    />
                    <div style="display: grid; gap: 4px; margin-top: 16px;">
                      <span class="team-card__name">{method.label}</span>
                      <span class="team-card__role">{method.value}</span>
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section id="resources" class="team-page resource-page">
        <img class="team-page__image" src="/eclipse-hero.png" alt="" />
        <div class="team-page__shade" aria-hidden="true"></div>

        <div class="team-panel">
          <h1 id="resources-title" class="page-heading">Learning Resources</h1>
          <p class="lede">Helpful resources for new team members and mentors.</p>
          <ul class="resource-list">
            <li>FTC Game Manual — official rules and updates.</li>
            <li>Programming Tutorials — basics of Java and robot control.</li>
            <li>CAD &amp; Fabrication Guides — tips for designing and building robots.</li>
          </ul>
        </div>
      </section>
    </main>

    <script>
      const observerOptions = {
        root: null,
        rootMargin: "-20% 0px -20% 0px",
        threshold: 0.1,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            const id = entry.target.getAttribute("id");
            updateActiveLink(id);
          }
        });
      }, observerOptions);

      const sections = Array.from(document.querySelectorAll<HTMLElement>("section[id]"));
      sections.forEach((section) => observer.observe(section));
      const topBarContainer = document.querySelector<HTMLElement>(".top-bar-container");
      const activePageTitle = document.querySelector<HTMLElement>("[data-active-page-title]");
      const sectionTitles: Record<string, string> = {
        home: "Eclipse 30618",
        team: "Team Roster",
        resources: "Learning Resources",
        contact: "Contact Us",
      };
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      let scrollAnimationId = 0;
      let lastScrollY = window.scrollY;
      let scrollTicking = false;
      let isSectionScrolling = false;
      let wheelDelta = 0;
      let wheelResetTimer = 0;
      let touchStartX = 0;
      let touchStartY = 0;
      let touchHandled = false;

      function updateActiveLink(id: string | null) {
        if (!id) return;
        if (activePageTitle) {
          activePageTitle.textContent = sectionTitles[id] ?? "Eclipse 30618";
        }

        const links = document.querySelectorAll(".top-bar__link");
        links.forEach((link) => {
          const href = link.getAttribute("href");
          if (href === `#${id}`) {
            link.classList.add("is-active");
          } else {
            link.classList.remove("is-active");
          }
        });
      }

      // Initial check for visibility on load
      document.addEventListener("DOMContentLoaded", () => {
        sections.forEach((section) => {
          const rect = section.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom >= 0) {
            section.classList.add("is-visible");
          }
        });
      });

      function getClosestSectionIndex() {
        let closestIndex = 0;
        let closestDistance = Number.POSITIVE_INFINITY;

        sections.forEach((section, index) => {
          const distance = Math.abs(section.getBoundingClientRect().top);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        return closestIndex;
      }

      function showTopBar(shouldPop = false) {
        if (!topBarContainer) return;

        const wasHidden = topBarContainer.classList.contains("is-hidden");
        topBarContainer.classList.remove("is-instant-hidden");
        topBarContainer.classList.remove("is-hidden");

        if (shouldPop && wasHidden && !prefersReducedMotion.matches) {
          topBarContainer.classList.remove("is-returning");
          void topBarContainer.offsetWidth;
          topBarContainer.classList.add("is-returning");
        }
      }

      function hideTopBar(immediate = false) {
        if (!topBarContainer) return;

        topBarContainer.classList.remove("is-returning");

        if (immediate) {
          topBarContainer.classList.add("is-instant-hidden");
          topBarContainer.classList.add("is-hidden");
          window.setTimeout(() => {
            topBarContainer.classList.remove("is-instant-hidden");
          }, 0);
          return;
        }

        topBarContainer.classList.add("is-hidden");
      }

      topBarContainer?.addEventListener("animationend", () => {
        topBarContainer.classList.remove("is-returning");
      });

      function easeInOutQuint(progress: number) {
        return progress < 0.5
          ? 16 * progress * progress * progress * progress * progress
          : 1 - Math.pow(-2 * progress + 2, 5) / 2;
      }

      function updateLocationHash(target: HTMLElement, mode: "push" | "replace" | "none") {
        if (mode === "none" || !target.id) return;

        const hash = `#${target.id}`;
        if (window.location.hash === hash) return;

        if (mode === "push") {
          history.pushState(null, "", hash);
        } else {
          history.replaceState(null, "", hash);
        }
      }

      function scrollToSection(targetIndex: number, direction: number, hashMode: "push" | "replace" | "none" = "replace") {
        const target = sections[targetIndex];
        if (!target) return;

        scrollAnimationId += 1;
        const animationId = scrollAnimationId;
        const startY = window.scrollY;
        const targetY = target.getBoundingClientRect().top + window.scrollY;
        const distance = targetY - startY;

        isSectionScrolling = true;

        if (direction !== 0) {
          hideTopBar(true);
        }
        updateActiveLink(target.id);

        if (prefersReducedMotion.matches || Math.abs(distance) < 2) {
          window.scrollTo(0, targetY);
          isSectionScrolling = false;
          lastScrollY = targetY;
          updateLocationHash(target, hashMode);
          showTopBar(true);
          return;
        }

        const duration = Math.min(1600, Math.max(1050, Math.abs(distance) * 0.72));
        const startTime = performance.now();

        function step(currentTime: number) {
          if (animationId !== scrollAnimationId) return;

          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easedProgress = easeInOutQuint(progress);

          window.scrollTo(0, startY + distance * easedProgress);

          if (progress < 1) {
            requestAnimationFrame(step);
          } else {
            window.scrollTo(0, targetY);
            isSectionScrolling = false;
            lastScrollY = targetY;
            updateLocationHash(target, hashMode);
            updateActiveLink(target.id);
            showTopBar(true);
            requestNavVisibilityUpdate();
          }
        }

        requestAnimationFrame(step);
      }

      function moveToSection(direction: number, hashMode: "push" | "replace" | "none" = "replace") {
        const currentIndex = getClosestSectionIndex();
        const targetIndex = Math.min(
          Math.max(currentIndex + direction, 0),
          sections.length - 1
        );

        if (targetIndex === currentIndex) return false;

        scrollToSection(targetIndex, direction, hashMode);
        return true;
      }

      document.querySelectorAll<HTMLAnchorElement>('.top-bar__link[href^="#"]').forEach((link) => {
        link.addEventListener("click", (event) => {
          const hash = link.getAttribute("href");
          if (!hash) return;

          const target = document.querySelector(hash);
          if (!target) return;

          const targetIndex = sections.findIndex((section) => section === target);
          if (targetIndex === -1) return;

          event.preventDefault();
          const direction = Math.sign(targetIndex - getClosestSectionIndex());
          scrollToSection(targetIndex, direction, "push");
        });
      });
      function updateScrollEclipse() {
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const progress = maxScroll > 0
          ? Math.min(Math.max(window.scrollY / maxScroll, 0), 1)
          : 0;

        document.documentElement.style.setProperty("--eclipse-scroll", progress.toFixed(4));
      }

      function updateNavVisibility() {
        const currentScrollY = Math.max(window.scrollY, 0);
        const scrollDelta = currentScrollY - lastScrollY;
        updateScrollEclipse();

        if (currentScrollY <= 8) {
          showTopBar();
        } else if (Math.abs(scrollDelta) > 4) {
          if (scrollDelta > 0 && currentScrollY > 112) {
            hideTopBar();
          } else if (scrollDelta < 0) {
            showTopBar(true);
          }
        }

        lastScrollY = currentScrollY;
        scrollTicking = false;
      }

      function requestNavVisibilityUpdate() {
        if (scrollTicking) return;
        scrollTicking = true;
        requestAnimationFrame(updateNavVisibility);
      }

      window.addEventListener("scroll", requestNavVisibilityUpdate, { passive: true });
      window.addEventListener("resize", requestNavVisibilityUpdate);
      window.addEventListener("wheel", (event) => {
        if (prefersReducedMotion.matches) return;
        if (Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;

        const direction = event.deltaY > 0 ? 1 : -1;
        const currentIndex = getClosestSectionIndex();
        const canMove =
          (direction > 0 && currentIndex < sections.length - 1) ||
          (direction < 0 && currentIndex > 0);

        if (!canMove) return;

        event.preventDefault();

        if (isSectionScrolling) return;

        wheelDelta += event.deltaY;
        window.clearTimeout(wheelResetTimer);
        wheelResetTimer = window.setTimeout(() => {
          wheelDelta = 0;
        }, 160);

        if (Math.abs(wheelDelta) < 36) return;

        wheelDelta = 0;
        moveToSection(direction);
      }, { passive: false });
      window.addEventListener("touchstart", (event) => {
        if (event.touches.length !== 1) return;

        touchStartX = event.touches[0].clientX;
        touchStartY = event.touches[0].clientY;
        touchHandled = false;
      }, { passive: true });
      window.addEventListener("touchmove", (event) => {
        if (prefersReducedMotion.matches || touchHandled || event.touches.length !== 1) {
          return;
        }

        const touch = event.touches[0];
        const deltaX = touchStartX - touch.clientX;
        const deltaY = touchStartY - touch.clientY;

        if (Math.abs(deltaY) < 52 || Math.abs(deltaY) <= Math.abs(deltaX) * 1.25) {
          return;
        }

        const direction = deltaY > 0 ? 1 : -1;

        if (isSectionScrolling) {
          event.preventDefault();
          return;
        }

        if (moveToSection(direction)) {
          event.preventDefault();
          touchHandled = true;
        }
      }, { passive: false });
      window.addEventListener("keydown", (event) => {
        if (
          event.defaultPrevented ||
          event.metaKey ||
          event.ctrlKey ||
          event.altKey
        ) {
          return;
        }

        const downKeys = ["ArrowDown", "PageDown", " "];
        const upKeys = ["ArrowUp", "PageUp"];
        const direction = downKeys.includes(event.key)
          ? event.shiftKey && event.key === " "
            ? -1
            : 1
          : upKeys.includes(event.key)
            ? -1
            : 0;

        if (direction !== 0 && moveToSection(direction)) {
          event.preventDefault();
        }
      });
      topBarContainer?.addEventListener("focusin", () => {
        showTopBar(true);
      });
      updateScrollEclipse();
      requestNavVisibilityUpdate();
    </script>
  </body>
</html>
