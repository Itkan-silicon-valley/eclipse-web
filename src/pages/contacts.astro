---
import "../styles/global.css";

const pageTitle = "Eclipse 30618 Contact";
const pageDescription = "Get in touch with FTC Team Eclipse 30618.";
const contactMethods = [
  { label: "Email", value: "team@eclipse30618.com", link: "mailto:team@eclipse30618.com" },
  { label: "Instagram", value: "@eclipse30618", link: "https://instagram.com/eclipse.30618" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://eclipse30618.com/contacts/" />
    <meta property="og:image" content="https://eclipse30618.com/eclipse-hero.png" />
    <meta name="theme-color" content="#050609" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="team-page">
      <img class="team-page__image" src="/eclipse-hero.png" alt="" />
      <div class="team-page__shade" aria-hidden="true"></div>

      <section class="team-panel" aria-labelledby="contact-title">
        <div class="team-panel__top">
          <a class="team-back" href="/">BACK</a>
          <p class="team-kicker">Eclipse 30618</p>
        </div>
        <h1 id="contact-title">Contact Us</h1>

        <ul class="team-grid" aria-label="Contact methods">
          {contactMethods.map((method) => (
            <li class="team-card">
              <a href={method.link} style="text-decoration: none; color: inherit; display: grid; gap: 8px;">
                <span class="team-card__name">{method.label}</span>
                <span class="team-card__role">{method.value}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
